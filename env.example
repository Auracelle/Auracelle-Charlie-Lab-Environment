# ── Auracelle Charlie — environment variable template ─────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control — it is listed in .gitignore.

# ── Authentication ─────────────────────────────────────────────────────────────
# Simulation login password shown on the login page.
# Default (dev only): charlie2025
CHARLIE_LOGIN_PASSWORD=charlie2025

# ── Admin dashboard ────────────────────────────────────────────────────────────
# PIN required to access the Admin Dashboard page.
# Default (dev only): 1234
ADMIN_PIN=1234

# ── Research database ──────────────────────────────────────────────────────────
# Relative or absolute path to the SQLite research database.
# Default: data/auracelle_research.db
CHARLIE_DB_PATH=data/auracelle_research.db

# ── FastAPI research backend ───────────────────────────────────────────────────
# URL of the optional FastAPI backend (used by Real-World Data Metrics).
# Leave as-is for local development.
CHARLIE_FASTAPI_URL=http://127.0.0.1:8000

# ── Optional: Agentic AI (Policy Owner / Red Team) ────────────────────────────
# Set this to enable GPT-4o-mini-backed Policy Owner and Red Team agents.
# Leave blank to use heuristic fallbacks (no API calls).
OPENAI_API_KEY=

# Optionally override the model and generation parameters:
# AURACELLE_OPENAI_MODEL=gpt-4o-mini
# AURACELLE_OPENAI_TEMPERATURE=0.4
# AURACELLE_OPENAI_MAX_TOKENS=700

# ── World Bank API ────────────────────────────────────────────────────────────
# No key required for wbgapi — public API.
# WB_CACHE_TTL controls how long (in seconds) World Bank data is cached.
# WB_CACHE_TTL=3600
